[package]
name = "chronos-crypto"
version = "0.1.0"
edition = "2021"

[dependencies]
sha2.workspace = true
kzen-paillier.workspace = true
num-bigint = { workspace = true, features = ["rand"] }
num-traits.workspace = true
curve25519-dalek = { workspace = true, features = ["rand_core"] }
rand.workspace = true
